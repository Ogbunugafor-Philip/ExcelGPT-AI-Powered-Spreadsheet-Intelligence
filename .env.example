# ===========================================================================
# ExcelGPT — Environment Configuration (example)
# Copy this file to backend/.env and fill in real values.
# Full documentation: architecture/environment-variables.md
# ===========================================================================

# Cerebras Cloud API key — powers the AI intent layer (action plan generation).
# Obtain one at https://cloud.cerebras.ai. Never commit the real value.
CEREBRAS_API_KEY=

# Cerebras model used for action-plan generation. Defaults to a fast 70B model
# suited to sub-second intent classification.
CEREBRAS_MODEL=llama-3.3-70b

# How long (seconds) to wait on a Cerebras response before failing the request.
CEREBRAS_TIMEOUT_SECONDS=20

# Sampling temperature for intent classification. Keep low for deterministic plans.
CEREBRAS_TEMPERATURE=0.1

# Max completion tokens for the action-plan JSON.
CEREBRAS_MAX_TOKENS=1200

# Comma-separated list of origins allowed by CORS.
# Use the Vercel frontend URL in production, localhost in development.
# Example: https://excelgpt.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Maximum upload size in megabytes. Files larger than this are rejected at /upload.
MAX_FILE_SIZE_MB=25

# Directory where uploaded files and generated .xlsx reports are stored on disk.
UPLOAD_DIR=./storage/uploads

# How long (in minutes) a session and its download token remain valid before expiry.
SESSION_EXPIRY_MINUTES=60

# Port the FastAPI/Uvicorn backend listens on.
BACKEND_PORT=8003

# Deployment environment: development | staging | production
ENVIRONMENT=development
