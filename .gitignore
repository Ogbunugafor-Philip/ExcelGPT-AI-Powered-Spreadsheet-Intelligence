storage/
backend/storage/
*.xlsx
*.xls
!**/templates/*.xlsx

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
